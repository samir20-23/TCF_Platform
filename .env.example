# ⚠️ hi here How TO GET  KEYS: FOLLOW THE STEPS BELOW 🙂👇

# --- SUPABASE CONFIGURATION ---
# Go to: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=_project_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=_anon_public_key_here

# Go to: Supabase Dashboard → Project Settings → API → service_role (Keep this secret)
SUPABASE_SERVICE_ROLE_KEY=_service_role_key_here


# --- STRIPE CONFIGURATION ---
# Go to: Stripe Dashboard → Developers → API Keys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY= 
STRIPE_SECRET_KEY= 

# Go to: Stripe Dashboard → Developers → Webhooks → Your endpoint → Signing secret
STRIPE_WEBHOOK_SECRET= 


# --- PAYPAL CONFIGURATION ---
# Go to: PayPal Developer Portal → Apps & Credentials → Your App
PAYPAL_CLIENT_ID=_paypal_client_id_here
PAYPAL_CLIENT_SECRET=_paypal_client_secret_here


# --- SITE CONFIGURATION ---
# Development (your local port)
NEXT_PUBLIC_SITE_URL=http://localhost:4029

# Production example
# NEXT_PUBLIC_SITE_URL=https://yourdomain.com